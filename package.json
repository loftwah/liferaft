{
  "name": "liferaft",
  "version": "0.1.0",
  "private": true,
  "description": "Local, read-only desktop app for indexing and recovering messages and attachments from large MBOX archives.",
  "type": "module",
  "main": "out/main/index.js",
  "author": "OpenAI Codex",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview --skipBuild",
    "start:built": "electron-vite preview",
    "preview": "electron-vite preview",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "@radix-ui/react-progress": "^1.1.7",
    "better-sqlite3": "^12.4.1",
    "dompurify": "^3.3.0",
    "electron-log": "^5.4.3",
    "mailparser": "^3.9.0",
    "mime-types": "^3.0.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-virtuoso": "^4.14.1",
    "sanitize-filename": "^1.6.3",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.1",
    "@tailwindcss/vite": "^4.1.16",
    "@types/better-sqlite3": "^7.6.13",
    "@types/mime-types": "^3.0.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "bun-types": "^1.3.4",
    "electron": "^41.0.0",
    "electron-vite": "^4.0.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.0"
  }
}
